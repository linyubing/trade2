classDiagram
    %% Database Models
    class Account {
        +String account_id
        +String api_key_hash
        +Decimal balance_usdt
        +Decimal unrealized_pnl
        +Decimal total_equity
        +DateTime updated_at
        +to_dict() Dict
    }

    class Position {
        +String position_id
        +String account_id
        +String symbol
        +String side
        +Decimal quantity
        +Decimal entry_price
        +Decimal mark_price
        +Decimal unrealized_pnl
        +DateTime opened_at
        +to_dict() Dict
    }

    class Order {
        +String order_id
        +String account_id
        +String symbol
        +String side
        +String type
        +Decimal quantity
        +Decimal price
        +String status
        +DateTime created_at
        +to_dict() Dict
    }

    class Trade {
        +String trade_id
        +String order_id
        +String account_id
        +String symbol
        +String side
        +Decimal quantity
        +Decimal price
        +Decimal commission
        +DateTime executed_at
        +to_dict() Dict
    }

    class MarketData {
        +String id
        +String symbol
        +String interval
        +BigInteger open_time
        +Decimal open
        +Decimal high
        +Decimal low
        +Decimal close
        +Decimal volume
        +BigInteger close_time
        +DateTime created_at
        +to_dict() Dict
    }

    class AgentDecision {
        +String decision_id
        +String account_id
        +String symbol
        +String action
        +Dict reasoning
        +String risk_check_result
        +DateTime decided_at
        +to_dict() Dict
    }

    class RiskEvent {
        +String event_id
        +String account_id
        +String event_type
        +Dict details
        +DateTime triggered_at
        +to_dict() Dict
    }

    %% Service Classes
    class Config {
        <<Singleton>>
        +String BINANCE_API_KEY
        +String BINANCE_API_SECRET
        +String OPENAI_API_KEY
        +String DATABASE_URL
        +Decimal MAX_POSITION_SIZE
        +Decimal MAX_DAILY_LOSS
        +load_config() Config
    }

    class Database {
        <<Singleton>>
        +Engine engine
        +SessionLocal session
        +init_db() void
        +get_db() Session
    }

    class MarketDataService {
        -Client client
        +get_klines(symbol, interval, limit) List~Dict~
        +get_ticker(symbol) Dict
        +get_account_balance() Dict
    }

    class AccountManager {
        -Session db
        -Client client
        +sync_account_state(account_id) Account
        +get_positions(account_id) List~Position~
        +update_position(position) void
    }

    class TradeExecutionService {
        -Session db
        -Client client
        -RiskManager risk_manager
        +place_order(account_id, symbol, side, qty, price) Order
        +cancel_order(account_id, order_id) bool
        +get_open_orders(account_id) List~Order~
    }

    class RiskManager {
        -Config config
        -Session db
        +validate_order(account_id, symbol, side, qty, price) Tuple~bool, str~
        +check_daily_loss(account_id) Tuple~bool, str~
        +check_position_limit(account_id, symbol) Tuple~bool, str~
    }

    class TradingAgent {
        -Config config
        -MarketDataService market_data
        -AccountManager account_mgr
        -TradeExecutionService trade_exec
        -RiskManager risk_mgr
        +tools List~Dict~
        +run_trading_cycle(account_id, symbol) Dict
        -_setup_tools() List~Dict~
        -_call_llm(messages) Dict
    }

    class TradingLoop {
        -TradingAgent agent
        -List~str~ symbols
        +run() void
        -_process_symbol(account_id, symbol) void
    }

    %% Relationships
    Account "1" --> "*" Position
    Account "1" --> "*" Order
    Account "1" --> "*" Trade
    Order "1" --> "*" Trade
    Account "1" --> "*" AgentDecision
    Account "1" --> "*" RiskEvent

    TradingLoop --> TradingAgent
    TradingAgent --> MarketDataService
    TradingAgent --> AccountManager
    TradingAgent --> TradeExecutionService
    TradingAgent --> RiskManager
    TradeExecutionService --> RiskManager
    MarketDataService --> Config
    AccountManager --> Database
    TradeExecutionService --> Database
    RiskManager --> Config
