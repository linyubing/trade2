# Exchange Configuration
BINANCE_API_KEY=your_testnet_api_key
BINANCE_API_SECRET=your_testnet_api_secret
BINANCE_TESTNET=True

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL_NAME=gpt-4

# Trading Configuration
TRADING_SYMBOL=BTCUSDT
TRADING_INTERVAL_MINUTES=60

# Risk Management Configuration
MAX_POSITION_SIZE=0.1
MAX_POSITIONS=3
STOP_LOSS_PERCENTAGE=5.0
TAKE_PROFIT_PERCENTAGE=10.0
TRADING_COOLDOWN_SECONDS=300

# Risk Parameters for System Prompt
EXTREME_STOP_LOSS_PERCENT=5
MAX_HOLDING_HOURS=24
MAX_LEVERAGE=25

# Database Configuration
DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/btc_quant

# Log Configuration
LOG_LEVEL=INFO

# Strategy Configuration
STRATEGY=ai-autonomous
ENABLE_CODE_LEVEL_PROTECTION=True
